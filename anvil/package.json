{
  "name": "anvil-monorepo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Anvil — agent-native multi-genre game engine",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm --filter @anvil/schema --filter @anvil/core --filter @anvil/cli --filter @anvil/render-phaser --filter @anvil/recipes run test",
    "lint": "eslint .",
    "validate:examples": "node packages/cli/dist/index.js validate examples/hello-empty",
    "test:examples": "node packages/cli/dist/index.js test examples/hello-empty",
    "dev:hello": "node packages/cli/dist/index.js dev examples/hello-empty",
    "anvil": "node packages/cli/dist/index.js"
  },
  "devDependencies": {
    "@anvil/cli": "workspace:*",
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8",
    "vite": "^6.0.3",
    "eslint": "^9.17.0",
    "typescript-eslint": "^8.18.0"
  }
}
